# Runtime artifacts — never commit
skills/auto-tune/cache/*
!skills/auto-tune/cache/.gitkeep
skills/auto-tune/security/quarantine/*
!skills/auto-tune/security/quarantine/.gitkeep

# User-derived lists (regenerated by trusted.py per-user)
skills/auto-tune/security/trusted_authors.txt
skills/auto-tune/security/trusted_repos.txt
skills/auto-tune/security/curators_synced.txt

# Per-user MCP connection state (which claude.ai MCPs the user has authenticated)
# Keep .example committed, real connection list stays local
skills/auto-tune/security/connected_mcps.txt
!skills/auto-tune/security/connected_mcps.txt.example

# Per-user subagent config — keep .example committed, real values stay local
skills/auto-tune/config/*.json
!skills/auto-tune/config/*.json.example

# Backups created by apply.py
**/*.autotune.bak

# Python noise
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.venv/

# OS noise
.DS_Store
Thumbs.db

# Editor noise
.idea/
.vscode/
*.swp
